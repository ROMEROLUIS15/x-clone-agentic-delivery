# =============================================================================
# Backend (used when running `npm run dev` from /backend with SQLite)
# =============================================================================
DATABASE_URL="file:./dev.db"
PORT=4000

# In dev a default secret is used if this is unset. In production the
# backend refuses to start without JWT_SECRET. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="change-me-in-production"

# =============================================================================
# Frontend (Vite dev server proxies /api to backend automatically)
# =============================================================================
VITE_API_URL=http://localhost:4000

# =============================================================================
# Docker Compose overrides (place at repo root, used by docker-compose.yml)
# =============================================================================
# Required in any real deployment — docker-compose will fail to start if unset.
# JWT_SECRET=replace-with-a-long-random-string

# Postgres credentials (default to "xclone" for local convenience)
# POSTGRES_USER=xclone
# POSTGRES_PASSWORD=change-me-too
# POSTGRES_DB=xclone
